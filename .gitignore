# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python

# ── Cython build artifacts (regenerated by `setup.py build_ext`) ─────
# Compiled extensions
*.so
*.pyd
# Cython-generated C/C++ + annotation HTML (per package)
aoslib/*.c
aoslib/*.cpp
aoslib/*.html
shared/*.c
shared/*.cpp
shared/*.html
vendor/pyenet/enet.c
vendor/pyenet/enet.html
# Cython output for the bot navigation wrapper; recast_bridge.cpp is authored.
server/bot_ai/recast.cpp
server/bot_ai/recast.html
# ...but keep any hand-written *_c.cpp helpers
!aoslib/*_c.cpp
!shared/*_c.cpp

# ── Packaging / distribution ────────────────────────────────────────
build/
dist/
release-dist/
develop-eggs/
downloads/
eggs/
.eggs/
sdist/
var/
wheels/
*.egg-info/
*.egg
.installed.cfg

# ── Virtual environments ────────────────────────────────────────────
venv/
.venv/
ENV/
env/

# ── Editors / IDEs ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Runtime output ──────────────────────────────────────────────────
logs/
*.log
server.log
config.local.toml

# ── Dev / research scratch (not part of the server) ─────────────────
tmp/
.deleted/
# physics captures / self-row samples
*.ndjson
selfrow_samples.ndjson
# IDA Pro databases
*.i64
*.exp
*.lib
*.obj

# ── Agent / assistant tooling ───────────────────────────────────────
.claude/
re-agent.yaml
codex-command-runner.exe
codex-windows-sandbox-setup.exe

# ── Sibling reference projects (kept outside the repo) ──────────────
ace.py/
aoslib-reversed/
aceofspades/

# ── Maps ────────────────────────────────────────────────────────────
# maps/*.vxl ARE tracked — the 4 stock Battle Builders maps ship with the
# server so a fresh clone runs out of the box. But ignore generated map
# artifacts (minimap thumbnails / compiled metadata) so a player's local
# game files aren't committed by accident.
/maps/*.txtc
/maps/*.png
