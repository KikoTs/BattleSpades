"""Disabled BattleSpades plugin example."""

from plugins.base_plugin import BasePlugin


class ExamplePlugin(BasePlugin):
    """Log one message when the operator explicitly enables this file."""

    name = "Example Plugin"
    version = "1.0.0"
    author = "BattleSpades contributors"

    async def on_load(self) -> None:
        """Announce successful plugin initialization."""

        import logging

        logging.getLogger(__name__).info("Example plugin loaded")
