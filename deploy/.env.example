# Immutable image produced by the GitHub container workflow.
BATTLESPADES_IMAGE=ghcr.io/kikots/battlespades
BATTLESPADES_IMAGE_TAG=main

# Public IPv4 of the UDP-capable game node. Do not use a private address.
AOS_PUBLIC_HOST=203.0.113.10
AOS_MASTER_URL=https://aosplay.net

# Use separate strong console passwords per instance.
SERVER_1_ADMIN_PASSWORD=
SERVER_2_ADMIN_PASSWORD=
SERVER_3_ADMIN_PASSWORD=

# One server-scoped aos_srv_* token per instance. Leave blank for the first
# boot, register the live port from this node, then store the returned token
# here and restart only that container.
AOS_SERVER_1_TOKEN=
AOS_SERVER_2_TOKEN=
AOS_SERVER_3_TOKEN=
